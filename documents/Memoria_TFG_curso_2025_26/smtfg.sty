\newcommand\poster{%
   \IfFileExists{poster/poster.pdf}{
      \clearemptydoublepage
      \bookmarksetup{startatroot,bold,color=mat!100}
      \phantomsection
      \addcontentsline{toc}{chapter}{Poster}
      \chapter*{\postername\@mkboth{\postername}{\postername}%
      }%
   \makeposter}{}
}



