\newcommand\ST[1]{%
   \def\ST{\sl#1}
   \newbox\LST
   \setbox\LST=\hbox{\large\ST}
   \logNTtrue
   \logSTtrue
}

\newcommand\InsST[1]{\def\InsST{#1}}
\newcommand\DptoST[1]{\def\DptoST{#1}}
\newcommand\EmST[1]{\def\EmST{#1}}

\newcommand\infoST{%
    \raisebox{-.9\height}{%
    \begin{minipage}[t]{.45\textwidth}
    \begin{flushleft}
    \noindent
    \link{\EmST}{\ST}\\
    \DptoST\\
    \InsST%\\
    \end{flushleft}
    \end{minipage}
    }
}

\newcommand\PT[1]{%
   \def\PT{\sl#1}
   \newbox\LPT
   \setbox\LPT=\hbox{\large\PT}
   \logNTtrue
   \logPTtrue
}

\newcommand\InsPT[1]{\def\InsPT{#1}}
\newcommand\DptoPT[1]{\def\DptoPT{#1}}
\newcommand\EmPT[1]{\def\EmPT{#1}}

\newcommand\CONV[2]{\def\CONV{#1 de #2}}

\newcommand\infoPT{%
   \raisebox{-.9\height}{
   \begin{minipage}[t]{.45\textwidth}
   \begin{flushleft}
   \link{\EmPT}{\PT}\\
   \DptoPT\\
   \InsPT%\\
   \end{flushleft}
   \end{minipage}
   }
}


