\newcommand{\intro}[1][\introname]{%
   \chapter*{#1}\markboth{#1}{#1}%
   \addcontentsline{toc}{chapter}{#1}
   \label{intropage}
   }

\newcommand{\ack}{%
   \chapter*{Agradecimientos}\markboth{Agradecimientos}{Agradecimientos}%
   \addcontentsline{toc}{chapter}{Agradecimientos}
   }

\newcommand{\abs}{%
   \chapter*{Resumen $\cdot$ Abstract}\markboth{Resumen $\cdot$ Abstract}%
   {Resumen $\cdot$ Abstract}
   \addcontentsline{toc}{chapter}{Resumen/Abstract}
   }

\newcommand{\acron}[1][\acronname]{%
   \chapter*{#1}\markboth{#1}{#1}%
   \addcontentsline{toc}{chapter}{#1}
   }

   
